                <mass value="0.274343" />
                <origin xyz="-0.00889167 0.000752118 0.044309" rpy="0 0 0" />
                <inertia ixx="0.000600595" ixy="-4.07754e-05" ixz="4.06403e-05" iyy="0.000397762" iyz="-8.45438e-05" izz="0.000397548" />
