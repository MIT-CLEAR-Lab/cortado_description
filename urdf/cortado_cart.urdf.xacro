<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="cortado_cart_description">
    <xacro:macro name="cortado_cart" params="prefix:='' camera_mast:=2">
        <xacro:property name="pp" value="${prefix + '_' if prefix else ''}" />
        <material name="vention_aluminium_blue">
            <color rgba="0.337255 0.533333 0.756863 1" />
        </material>
        <material name="dark_gray_plastic">
            <color rgba="0.156863 0.156863 0.156863 1" />
