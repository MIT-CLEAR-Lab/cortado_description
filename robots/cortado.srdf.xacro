<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="$(arg robot_name)">
  <xacro:arg name="robot_name" default="cortado" />
  <xacro:arg name="prefix" default="" />

  <xacro:include filename="common/cortado.srdf.xacro" />

  <xacro:cortado_srdf prefix="$(arg prefix)" />
</robot>
